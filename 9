import os

with open('input_9.txt', 'r', encoding='utf-8') as f:
    lines = f.readlines()

os.makedirs('simple', exist_ok=True)

even_lines = []
for i in range(1, len(lines), 2):
    even_lines.append(lines[i])

with open('output_9.txt', 'w', encoding='utf-8') as f:
    f.writelines(even_lines)

print("Готов")
